# Keep the build context clean + reproducible. Anything here is NOT copied into
# the image, so local junk / secrets / stale caches can't leak in.
.git
.gitignore
.env
.env.*
node_modules
vendor
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*.php
public/build
*.md
tests
.github
